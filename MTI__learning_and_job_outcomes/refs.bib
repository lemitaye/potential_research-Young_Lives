}

@Article{munshi_traditional_2006,
  author     = {Munshi, Kaivan and Rosenzweig, Mark},
  title      = {Traditional Institutions Meet the Modern World: Caste, Gender, and Schooling Choice in a Globalizing Economy},
  issn       = {0002-8282},
