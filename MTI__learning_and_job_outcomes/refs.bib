	shorttitle = {General {Mental} {Ability} in the {World} of {Work}},
	doi = {10.1037/0022-3514.86.1.162},
	abstract = {The psychological construct of general mental ability (GMA), introduced by C. Spearman (1904) nearly 100 years ago, has enjoyed a resurgence of interest and attention in recent decades. This article presents the research evidence that GMA predicts both occupational level attained and performance within one's chosen occupation and does so better than any other ability, trait, or disposition and better than job experience. The sizes of these relationships with GMA are also larger than most found in psychological research. Evidence is presented that weighted combinations of specific aptitudes tailored to individual jobs do not predict job performance better than GMA alone, disconfirming specific aptitude theory. A theory of job performance is described that explicates the central role of GMA in the world of work. These findings support Spearman's proposition that GMA is of critical importance in human affairs. (PsycINFO Database Record (c) 2016 APA, all rights reserved)},
	number = {1},
	journal = {Journal of Personality and Social Psychology},
	author = {Schmidt, Frank L. and Hunter, John},
	year = {2004},
	note = {Place: US
Publisher: American Psychological Association},
	keywords = {Cognitive Ability, Job Experience Level, Job Performance, Occupational Success, Occupations, Theories},
	pages = {162--173},
	file = {Snapshot:C\:\\Users\\ldaba\\Zotero\\storage\\L4UP7GV5\\2003-11198-011.html:text/html},
}

@article{moffitt_gradient_2011,
	title = {A gradient of childhood self-control predicts health, wealth, and public safety},
	volume = {108},
	issn = {0027-8424},
	url = {https://www.ncbi.nlm.nih.gov/pmc/articles/PMC3041102/},
	doi = {10.1073/pnas.1010076108},
	abstract = {Policy-makers are considering large-scale programs aimed at self-control to improve citizens’ health and wealth and reduce crime. Experimental and economic studies suggest such programs could reap benefits. Yet, is self-control important for the health, wealth, and public safety of the population? Following a cohort of 1,000 children from birth to the age of 32 y, we show that childhood self-control predicts physical health, substance dependence, personal finances, and criminal offending outcomes, following a gradient of self-control. Effects of children's self-control could be disentangled from their intelligence and social class as well as from mistakes they made as adolescents. In another cohort of 500 sibling-pairs, the sibling with lower self-control had poorer outcomes, despite shared family background. Interventions addressing self-control might reduce a panoply of societal costs, save taxpayers money, and promote prosperity.},
	number = {7},
	urldate = {2023-12-03},
	journal = {Proceedings of the National Academy of Sciences of the United States of America},
	author = {Moffitt, Terrie E. and Arseneault, Louise and Belsky, Daniel and Dickson, Nigel and Hancox, Robert J. and Harrington, HonaLee and Houts, Renate and Poulton, Richie and Roberts, Brent W. and Ross, Stephen and Sears, Malcolm R. and Thomson, W. Murray and Caspi, Avshalom},
	month = feb,
	year = {2011},
	pmid = {21262822},
	pmcid = {PMC3041102},
	pages = {2693--2698},
	file = {PubMed Central Full Text PDF:C\:\\Users\\ldaba\\Zotero\\storage\\E7JHSGS4\\Moffitt et al. - 2011 - A gradient of childhood self-control predicts heal.pdf:application/pdf},
}


@article{taye_medium_2019,
	title = {The medium of instruction in {Ethiopian} {Higher} {Education} {Institutions}: {Kotebe} {Metropolitan} {University} {Case} study.},
	volume = {8},
	copyright = {Copyright (c) 2019 African Journal of Teacher Education},
	issn = {1916-7822},
	shorttitle = {The medium of instruction in {Ethiopian} {Higher} {Education} {Institutions}},
	url = {https://journal.lib.uoguelph.ca/index.php/ajote/article/view/4367},
	doi = {10.21083/ajote.v8i0.4367},
	abstract = {The aim of this article is to examine the medium of instruction in Ethiopian higher education institutions and the perceived consequences of the failure to learn a lingua franca. The study was qualitative and it used interviews and focus group discussions (FGDs). Five teachers and five students took part in the interviews and six teachers and six students participated in the FGDs. The findings of the study showed that the role of Amharic as a working language has not been given recognition despite the fact that Amharic was constitutionally granted to be a working language. Due to language barriers, students who are speakers of Oromipha and other languages from the Eastern and Western parts of Ethiopia suffer passivity in the classroom because they do not speak Amharic although Amharic has been taught as a subject in all regional states of the country. Increased identity politics seems to have generated a negative attitude towards Amharic, Ethiopia's former official lingua franca. Non-Amharic native speakers appeared to lose interest in learning Amharic while they were in primary and secondary schools. The absence of an official, common language which could be used for wider communication in higher education has resulted in having challenges among the student population.},
	language = {en},
	urldate = {2023-12-16},
	journal = {African Journal of Teacher Education},
	author = {Taye, Bekau Atnafu},
	month = apr,
	year = {2019},
	pages = {1--24},
	file = {Full Text PDF:C\:\\Users\\user\\Zotero\\storage\\2T9GFYM4\\Taye - 2019 - The medium of instruction in Ethiopian Higher Educ.pdf:application/pdf},
}


